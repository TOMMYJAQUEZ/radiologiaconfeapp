rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar: verificar si es admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }
    
    // Función auxiliar: verificar si es el mismo usuario
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // Función auxiliar: verificar autenticación
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Colección: users
    match /users/{userId} {
      // Leer: Solo el usuario mismo o admin
      allow read: if isOwner(userId) || isAdmin();
      
      // Escribir: Solo el usuario mismo (crear y actualizar)
      allow create: if isOwner(userId) && request.resource.data.rol == 'estudiante';
      allow update: if isOwner(userId) && !('rol' in request.resource.data.diff(resource.data));
      allow delete: if false;
      
      // Subcolección: quiz_responses
      match /quiz_responses/{responseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
      
      // Subcolección: achievements
      match /achievements/{achievementId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Sistema automático
      }
      
      // Subcolección: access_log
      match /access_log/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
    
    // Colección: quizzes/preguntas
    match /quizzes/preguntas/{preguntaId} {
      // Leer: Cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: Solo admin
      allow write: if isAdmin();
    }
    
    // Colección: anatomia (estructuras)
    match /anatomia/sistemas/{sistema}/estructuras/{estructura} {
      // Leer: Cualquier usuario autenticado
      allow read: if isAuthenticated();
      
      // Escribir: Solo admin
      allow write: if isAdmin();
    }
    
    // Colección: grupos
    match /grupos/{grupoId} {
      // Leer: Admin o miembros del grupo
      allow read: if isAdmin() || 
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.grupo == grupoId;
      
      // Escribir: Solo admin
      allow write: if isAdmin();
      
      // Subcolección: estudiantes
      match /estudiantes/{studentId} {
        allow read: if isAdmin() || isOwner(studentId);
        allow write: if isAdmin();
      }
    }
    
    // Colección: configuracion
    match /configuracion/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Colección: logros (definiciones)
    match /logros/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Colección: analytics/eventos
    match /analytics/eventos/{eventId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    
    // Default: denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
